# --- Contact form ---------------------------------------------------------
# Formspree (https://formspree.io) or Web3Forms (https://web3forms.com).
# Set this BEFORE deploying or the contact form will only print a friendly
# warning to visitors.
PUBLIC_FORM_ENDPOINT=https://formspree.io/f/your-form-id

# --- APK downloads --------------------------------------------------------
# Base URL where the signed beta APKs live. The site appends the per-app
# filename (e.g. tazkirah-v01.apk) to this base.
#
# RECOMMENDED: GitHub Releases — free, unmetered, 2 GB/file. After cutting a
# release `v0.1.0-beta` with both APKs attached, the base URL is:
#
#   https://github.com/<github-user>/zikrapps/releases/download/v0.1.0-beta
#
# Leave this UNSET locally to serve APKs from public/downloads/ for dev work.
PUBLIC_APK_BASE_URL=
