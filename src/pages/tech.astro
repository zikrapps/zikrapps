  <!-- Open source -->
  <section class="bg-forest text-cream py-8 sm:py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <div class="grid items-center gap-8 sm:grid-cols-[1fr_auto]">
        <div>
          <p class="text-xs font-semibold tracking-[0.2em] text-gold-light uppercase">
            Open source
