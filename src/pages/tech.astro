// Hidden engineering write-up. Reachable at /tech and (via middleware) at the
// tech.zikrapps.com hostname. Intentionally not linked from any site nav.
const locale = 'en';
const t = getTranslations(locale);

const pageTitle = 'From flaky to flawless';
const pageDescription =
  'A story of debugging an unreliable automated test setup for our Misbaha app — the dead ends, the root cause, and the fix — with before/after diagrams.';

const heroStats = [
  { label: 'Automated runs', value: '150' },
  { label: 'Final pass rate', value: '100%' },
  { label: 'Distinct issues fixed', value: '13' },
  { label: 'Worst point', value: '84%' },
];

// How the testing works, in plain terms.
const methodology = [
  {
    title: 'Five everyday journeys',
    body: 'We picked the five things people actually do in Misbaha and scripted each one end to end, the way a real person would tap through it.',
  },
  {
    title: 'Thirty times each',
    body: 'We run every journey 30 times — 150 runs in total. Flakiness hides from a single run: a glitch that strikes 1 time in 20 is invisible unless you repeat the test enough to catch it.',
  },
  {
    title: 'A clean slate every time',
    body: 'Before each run the app is reset to a known starting state and we wait until it is genuinely ready, so one test can never contaminate the next.',
  },
  {
    title: 'One phone at a time',
    body: 'After discovering the engine was tripping over itself, we run on a single simulated phone, one journey after another, for dependable results.',
  },
  {
    title: 'All-or-nothing scoring',
    body: 'A run only counts as a pass if every required step in the journey succeeds. Anything less is a fail.',
  },
  {
    title: 'Measure, fix, measure again',
    body: 'We measure reliability first (the "baseline"), fix the causes of every failure, then measure again (the "hardened" run) to prove the improvement.',
  },
];

// The five user journeys (plain-language, mapped from the internal flows A–E).
const journeys = [
  {
    n: 1,
    title: 'Open the app',
    desc: 'Cold-start Misbaha and land on a ready Today screen with no pop-ups in the way.',
  },
  {
    n: 2,
    title: 'Count a dhikr',
    desc: 'Open the Tasbeeh tab, choose a supplication, count it, and confirm the tally goes up.',
  },
  {
    n: 3,
    title: 'Search for a supplication',
    desc: 'Search the duas by name and open a matching result.',
  },
  {
    n: 4,
    title: 'Start a surprise goal',
    desc: 'Begin a randomly chosen multi-day goal and confirm it appears in the active goals list.',
  },
  {
    n: 5,
    title: 'Leave and come back',
    desc: 'Count, switch away from the app, return, and confirm the count was preserved.',
  },
];

// Per-journey pass rates: baseline (the 84.6% run) vs hardened (the 100% run).
const results = [
  { journey: 'Open the app', checks: 'Stable launch', basePass: 27, hardPass: 30 },
  { journey: 'Count a dhikr', checks: 'Counting works', basePass: 21, hardPass: 30 },
  { journey: 'Search for a supplication', checks: 'Search + open', basePass: 25, hardPass: 30 },
  { journey: 'Start a surprise goal', checks: 'Goal created', basePass: 24, hardPass: 30 },
  { journey: 'Leave and come back', checks: 'State persists', basePass: 29, hardPass: 30 },
];
const RUNS_PER = 30;
const baseTotal = results.reduce((a, r) => a + r.basePass, 0);
const hardTotal = results.reduce((a, r) => a + r.hardPass, 0);
const pct = (n: number, d: number) => Math.round((n / d) * 100);

// Reliability metrics (computed from the per-run result files of the baseline
// 84.6% batch vs the hardened 100% batch). Plain-language "meaning" for non-experts.
const metrics = [
  {
    name: 'Success rate',
    meaning: 'How often a journey passes',
    base: '84.6%',
    hard: '100%',
  },
  {
    name: 'Flake rate',
    meaning: 'Runs that disagreed with the usual result',
    base: '15.4%',
    hard: '0%',
  },
  {
    name: 'Reproducibility',
    meaning: 'Journeys that gave the same verdict every time',
    base: '0 of 5',
    hard: '5 of 5',
  },
  {
    name: 'False alarms',
    meaning: 'Failures where the app was actually fine',
    base: 'all 23 failures',
    hard: '0',
  },
  {
    name: 'When failures struck',
    meaning: 'How far into a journey it broke',
    base: 'at the first step',
    hard: 'n/a — none failed',
  },
  {
    name: 'Diagnosed failures',
    meaning: 'Failures we could explain and categorise',
    base: '100%',
    hard: '100%',
  },
];

// Failure taxonomy — the standard QA classes, with how many of our 13 issues fell
// into each and a plain-language note.
const taxonomy = [
  {
    cls: 'App bug',
    count: 2,
    note: 'Genuine defects in the app, found by the tests and fixed in the app\u2019s code.',
  },
  {
    cls: 'Test design bug',
    count: 3,
    note: 'The test itself was wrong — pointing at the wrong thing or making a bad assumption.',
  },
  {
    cls: 'Agent / timing error',
    count: 2,
    note: 'The test acted before the app had finished drawing. This caused all 23 of the baseline run failures.',
  },
  {
    cls: 'Environment / infrastructure',
    count: 6,
    note: 'Device, build, or test-engine plumbing broke — including the root-cause crash.',
  },
  {
    cls: 'State drift',
    count: 0,
    note: 'Prevented by design: every run starts from a clean, reset state.',
  },
  {
    cls: 'Weak check (oracle)',
    count: 0,
    note: 'Prevented by design: we check real numbers (the count went up by 3), not just that "some text exists".',
  },
  {
    cls: 'Unknown',
    count: 0,
    note: 'Every single failure was explained — nothing left unclassified.',
  },
];

// Pinned environment + harness facts.
const environment = [
  { k: 'App', v: 'Misbaha 1.2.0 (build 3)' },
  { k: 'Platform', v: 'iOS 26.3 — iPhone 17 Pro Simulator' },
  { k: 'Test engine', v: 'DevLoop 0.0.96 (QualGent)' },
  { k: 'Runs per batch', v: '5 journeys \u00d7 30 = 150' },
  { k: 'Execution', v: 'One simulator, sequential' },
  { k: 'Clean slate', v: 'Reset deep link + readiness wait before each run' },
];

const toc = [
  { id: 'meet', label: 'Meet Misbaha' },
  { id: 'open-source', label: 'The code is on GitHub' },
  { id: 'stack', label: 'How Misbaha is built' },
  { id: 'about', label: 'What this is about' },
  { id: 'method', label: 'How we test' },
  { id: 'journeys', label: 'The five journeys' },
  { id: 'results', label: 'Results by journey' },
  { id: 'scorecard', label: 'The reliability scorecard' },
  { id: 'issues', label: 'Every issue, before and after' },
  { id: 'taxonomy', label: 'Sorting failures by type' },
  { id: 'categories', label: 'How to read the categories' },
  { id: 'setup', label: 'The exact setup' },
  { id: 'limitations', label: 'Honest limitations' },
  { id: 'takeaway', label: 'The takeaway' },
];

const limitations = [
  'Running one phone at a time is slower than running many — that was the trade we made for dependable results until the test engine stops launching duplicate controllers.',
  'The surprise goal is random on purpose, so we check that a goal was created, not which one.',
  'Because we test a packaged build, code changes need a rebuild before the tests exercise them.',
  'These numbers come from one before batch and one after batch; more batches would tighten the confidence further.',
];

// --- Static SVG flow-diagram generator --------------------------------------
// Renders a vertical sequence of rounded boxes joined by arrows. The final box
// is tinted by variant (before = red outcome, after = green outcome). No
// client-side dependency: the SVG is emitted at build time.
function esc(s: string): string {
  return String(s)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
}

function flowSvg(steps: string[], variant: 'before' | 'after', uid: string): string {
  const W = 300;
  const nodeW = 264;
  const x = (W - nodeW) / 2;
  const fs = 13;
  const lh = 17;
  const vpad = 11;
  const gap = 30;
  const accent = variant === 'before' ? '#c0392b' : '#1e8449';
  const accentBg = variant === 'before' ? '#fdecea' : '#e9f7ef';
  const marker = `arrow-${uid}`;

  let y = 6;
  const boxes: string[] = [];
  const rows: { topY: number; bottomY: number }[] = [];

  steps.forEach((step, i) => {
    const lines = String(step).split('\n');
    const h = lines.length * lh + 2 * vpad;
    const isLast = i === steps.length - 1;
    const fill = isLast ? accentBg : '#ffffff';
    const stroke = isLast ? accent : '#0b3d2e';
    const textColor = isLast ? accent : '#0b3d2e';
    const sw = isLast ? 2 : 1.2;
    boxes.push(
      `<rect x="${x}" y="${y}" width="${nodeW}" height="${h}" rx="12" fill="${fill}" stroke="${stroke}" stroke-width="${sw}"/>`
    );
    const firstBaseline = y + vpad + fs - 2;
    const tspans = lines
      .map((ln, li) => `<tspan x="${W / 2}" dy="${li === 0 ? 0 : lh}">${esc(ln)}</tspan>`)
      .join('');
    boxes.push(
      `<text x="${W / 2}" y="${firstBaseline}" text-anchor="middle" font-family="DM Sans, system-ui, sans-serif" font-size="${fs}" font-weight="${isLast ? 600 : 500}" fill="${textColor}">${tspans}</text>`
    );
    rows.push({ topY: y, bottomY: y + h });
    y += h + gap;
  });

  let arrows = '';
  for (let i = 0; i < rows.length - 1; i++) {
    arrows += `<line x1="${W / 2}" y1="${rows[i].bottomY}" x2="${W / 2}" y2="${rows[i + 1].topY - 7}" stroke="#b8956a" stroke-width="1.6" marker-end="url(#${marker})"/>`;
  }

  const totalH = y - gap + 6;
  return `<svg viewBox="0 0 ${W} ${totalH}" width="100%" height="auto" role="img" aria-label="${variant} fix flow" xmlns="http://www.w3.org/2000/svg">
  <defs><marker id="${marker}" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse"><path d="M0,0 L10,5 L0,10 z" fill="#b8956a"/></marker></defs>
  ${arrows}${boxes.join('')}</svg>`;
}

// --- Issues (plain story + before/after steps + engineering detail) ----------
const rawIssues = [
  {
    id: 'bundle-id',
    title: 'Opening the wrong app',
    category: 'Test config',
    plain:
      'Think of every app on a phone as having a unique badge number. Our test handed out the wrong badge number, so it kept knocking on the wrong door.',
    before: ['Test run', "Open app\n'wrong-id'", 'Phone: no such app', 'Every test fails'],
    after: ['Test run', "Open app\n'correct-id'", 'Phone opens Misbaha', 'Tests proceed'],
    fix: "Corrected the app's badge number (its bundle identifier) everywhere the test referred to it.",
    tech:
      "The harness's APP_BUNDLE constant was stale. Every apply_routine / mobile_launch_app call targets a bundle id, and it must match the installed binary. Set it to com.zikrapps.misbaha across the harness and routine definitions.",
  },
  {
    id: 'parallelism',
    title: 'Too many phones at once',
    category: 'Parallel vs. single-thread',
    plain:
      'Running many simulated phones at the same time is like opening too many programs on an old laptop — everything slows to a crawl and things start failing for no real reason.',
    before: ['1 laptop runs\n5 phones at once', 'CPU saturated', 'Steps time out', '4 of 5 fail'],
    after: ['1 laptop runs\n1 phone at a time', 'Resources comfortable', 'Tests stay stable'],
    fix: 'Reduced from 5 simultaneous phones to a single phone running tests one after another.',
    tech:
      'Five concurrent simulators saturated the CPU on a 16 GB M4 Air; XCUITest steps blew past postcondition timeouts. Each simulator also runs its own WebDriverAgent, so per-device overhead — not test logic — was the bottleneck. Dropped to 2, then to single-sim sequential.',
  },
  {
    id: 'build-id',
    title: 'The app built with the wrong ID',
    category: 'Build / tooling',
    plain:
      'Even after fixing the test, the app itself had been manufactured with the wrong badge number printed on it. Both sides have to match.',
    before: ["Test looks for\n'correct-id'", "Installed app is\n'other-id'", 'Mismatch → not found'],
    after: ["Test looks for\n'correct-id'", "Rebuilt app is\n'correct-id'", 'Match → found'],
    fix: 'Set the correct identifier in the app build settings, then rebuilt and reinstalled it.',
    tech:
      'PRODUCT_BUNDLE_IDENTIFIER in project.pbxproj was com.misbaha.app for both Debug and Release. Rebuilt with com.zikrapps.misbaha so the installed id matches the routine target.',
  },
  {
    id: 'dialog',
    title: 'A pop-up kept blocking everything',
    category: 'Test flow',
    plain:
      'To save time, tests used shortcuts to jump between screens. But each shortcut made the phone ask "Are you sure you want to open Misbaha?" — and a question nobody answered stopped the test cold.',
    before: ['Test taps a shortcut', "System pop-up:\n'Open in Misbaha?'", 'Nobody answers', 'Test stuck → fails'],
    after: ['Test taps a real button', 'Screen changes normally', "Pop-up? auto-tap 'Open'", 'Test continues'],
    fix: 'Switched navigation to tapping the app\u2019s real buttons, and taught the test to automatically confirm any pop-up that still appears.',
    tech:
      'Custom-scheme deep links (misbaha://test/go/{tab}) trigger the iOS "Open in app?" confirmation. Replaced open_url navigation with tap_element on tab testIDs, and added a confirm_scheme_dialog helper that taps "Open" when a prompt is detected.',
  },
  {
    id: 'router-race',
    title: 'The app crashed when tests moved too fast',
    category: 'Real app bug',
    plain:
      'A person taking a fraction of a second to react never notices, but a robot is instant. It told the app to switch screens before the app had even finished opening, and the app fell over.',
    before: ['App starts opening', 'Robot instantly:\ngo to next screen', 'App not ready', 'White crash screen'],
    after: ['App starts opening', 'App finishes setup', 'Then it navigates', 'No crash'],
    fix: 'Made the app defer the screen change by one frame, so it only navigates once it is fully mounted and ready.',
    tech:
      'expo-router router.replace() ran inside a test route useEffect before the Root Layout mounted → "Attempted to navigate before mounting the Root Layout". Deferred the call with requestAnimationFrame in app/test/reset.tsx and app/test/go/[tab].tsx.',
  },
  {
    id: 'silent-errors',
    title: 'Errors were happening silently',
    category: 'Real app bug',
    plain:
      'The app had a safety net that caught crashes so users would not see them — but it threw the details away, leaving us blind to what actually broke.',
    before: ['Something breaks', 'Safety net catches it', 'Details discarded', 'We cannot diagnose'],
    after: ['Something breaks', 'Safety net catches it', 'Details logged', 'Root cause visible'],
    fix: 'Added error logging to the safety net so every caught error is recorded with its cause.',
    tech:
      'The ErrorBoundary implemented getDerivedStateFromError for fallback UI but had no componentDidCatch, so stacks were swallowed. Added componentDidCatch logging to surface the error and component stack.',
  },
  {
    id: 'stuck-leases',
    title: 'Phones got "stuck" and unavailable',
    category: 'Infrastructure',
    plain:
      'Each test "reserves" a phone, like checking out a library book. When a test crashed hard, it never returned the book — so the next test was told everything was checked out.',
    before: ['Test reserves phone', 'Test crashes hard', 'Phone never released', "Next run: 'all busy'"],
    after: ['Test reserves phone', 'Run ends (even on error)', 'Phone auto-released', 'Next run starts clean'],
    fix: 'Cleared the stuck reservations and ensured runs always release their phone, even when they fail.',
    tech:
      'Force-killed harness processes left qg_acquire_device leases dangling (no finally ran), so the bridge returned device-busy from another "external session". Guaranteed release in a finally block; cleared orphaned leases with a bridge restart.',
  },
  {
    id: 'metro',
    title: 'Stuck on "Downloading 100%"',
    category: 'Build / tooling',
    plain:
      'The test version of the app downloaded its code live from a developer server every launch. When that server hiccuped, the app froze on a loading bar.',
    before: ['App launches', 'Fetch code from\ndev server', 'Server stalls', "Frozen at\n'Downloading 100%'"],
    after: ['App launches', 'Code baked inside', 'Opens instantly,\noffline'],
    fix: 'Built a self-contained release version with all code bundled inside, removing the live download.',
    tech:
      'The dev client streamed its JS bundle from Metro; a stall left the app on "Downloading 100%". Switched to a Release build with the Hermes bundle embedded (keeping EXPO_PUBLIC_E2E=1), eliminating the Metro runtime dependency.',
  },
  {
    id: 'stale-routine',
    title: 'Looking for a button that had moved',
    category: 'Test maintenance',
    plain:
      'The counting test was written for an older version of the screen. The app had since been redesigned, so the test reached for things that were no longer there.',
    before: ['Counting test', 'Look for old\nmenu item', 'It was removed', 'Cannot find it → fail'],
    after: ['Counting test', 'Open current category', 'Press & hold to count', 'Reliable every time'],
    fix: 'Rewrote the test against the current screen and used a steady press-and-hold gesture instead of fragile rapid taps.',
    tech:
      'expand_dua_and_count referenced a removed category and timing-fragile double taps. Rebuilt as v8: open "Quranic Duas", then a zero-displacement swipe_coordinates (~3.2 s long-press) for a deterministic count increment.',
  },
  {
    id: 'goal-timing',
    title: 'Tapping before the screen was ready',
    category: 'Test timing',
    plain:
      'The "new goal" test moved to a screen and immediately tapped a button there — but under load, the screen took an extra moment to draw, so the tap missed.',
    before: ['Open Goals screen', 'Immediately tap button', 'Screen still drawing', 'Button missing → fail'],
    after: ['Open Goals screen', 'Wait until it appears', 'Then tap the button', 'Works under load'],
    fix: 'Added a "wait until the screen has changed" check before each tap on that flow.',
    tech:
      'start_surprise_goal tapped surprise-goal-button before the Goals screen rendered, failing 7/30 under load. Hardened as v4 with wait_for: screen_changed (6 s timeout) on the navigation steps.',
  },
  {
    id: 'splash',
    title: 'Starting before the app woke up',
    category: 'Test reset logic',
    plain:
      'Between tests we restart the app. We used to wait a fixed number of seconds — but on a busy laptop that guess was too short, so tests began while only the splash logo was showing.',
    before: ['Restart app', 'Wait a fixed 2 s', 'Busy: still on splash', 'Act on blank → fail'],
    after: ['Restart app', 'Keep checking the screen', 'Home content visible?', 'Begin the test'],
    fix: 'Replaced the fixed wait with an active poll that proceeds only once real home-screen content is on screen.',
    tech:
      'hard_reset used fixed sleeps; under load the launch splash outlasted them and the first tap hit a bare splash ("Visible: Misbaha"). Added wait_until_ready, which polls mobile_observe_screen for home markers before any routine runs.',
  },
  {
    id: 'retries',
    title: 'The robot kept losing connection',
    category: 'Infrastructure',
    plain:
      'The automation engine occasionally dropped its connection mid-test. A momentary network blip is not a real product problem, but it was being counted as a test failure.',
    before: ['Run a step', 'Connection blips', 'Counted as failure'],
    after: ['Run a step', 'Connection blip?', 'Pause, recover, retry', 'Continue'],
    fix: 'Added automatic retries with a short backoff and a recovery step, so transient blips no longer fail a test.',
    tech:
      'Transient bridge disconnects ("All connection attempts failed" / "Server disconnected") surfaced as execution_error. apply_with_retry catches RuntimeError and recoverable traces, backs off (min(4·n, 15) s), and runs recover_to_today between attempts; real failures still return immediately.',
  },
  {
    id: 'wda-collision',
    title: 'Two robots fighting over one phone',
    category: 'Infrastructure (root cause)',
    plain:
      'This was the real villain. The automation engine was quietly starting two identical control programs on the same phone. Both tried to use the same single "doorway" (a network port), collided, and crashed — taking the whole test down with them. Restarting one phone helped briefly, then it came back.',
    before: ['Automation engine', 'Starts TWO controllers\non one phone', 'Both grab the same port', 'Collision → crash', "'Connection failed'\non every test"],
    after: ['Engine restarted,\nduplicates cleared', 'One controller,\none phone', 'Stable connection', '150 / 150 pass'],
    fix: 'Ran a single phone sequentially and restarted the automation engine to clear the duplicate control programs and stuck reservations.',
    tech:
      'The crash report showed WebDriverAgent aborting in -[FBWebServer startHTTPServer] (FBWebServer.m:124) — a GCDWebServer port-bind failure caused by duplicate "xcodebuild test … WebDriverAgent" launchers targeting the same simulator. The second instance could not bind the WDA port and aborted, so every apply_routine returned "All connection attempts failed". Fixed by single-sim sequential execution plus a QualGent Desktop restart to clear duplicate runners and stale leases.',
  },
];

const issues = rawIssues.map((issue) => ({
  ...issue,
  beforeSvg: flowSvg(issue.before, 'before', `${issue.id}-b`),
  afterSvg: flowSvg(issue.after, 'after', `${issue.id}-a`),
}));

const categories = [
  { name: 'Real app bug', desc: 'A genuine defect in the app, fixed in the app\u2019s code.' },
  { name: 'Infrastructure', desc: 'A problem in the testing engine or device plumbing, not the app.' },
  { name: 'Parallel vs. single-thread', desc: 'Caused by running too much at once on one machine.' },
  { name: 'Build / tooling', desc: 'How the app was packaged for testing.' },
  { name: 'Test config / maintenance', desc: 'The test scripts pointed at the wrong thing or had gone stale.' },
  { name: 'Test timing / flow', desc: 'The test acted faster than the app could respond.' },
];

const lastUpdated = 'June 2026';

