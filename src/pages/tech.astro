---

<BaseLayout locale={locale} t={t} title={pageTitle} description={pageDescription} linkOrigin={Astro.site}>
  <!-- Hero -->
  <section class="bg-forest text-cream">
    <div class="mx-auto max-w-4xl px-4 py-10 sm:px-6 sm:py-12">
      <p class="text-xs font-semibold tracking-[0.2em] text-gold-light uppercase">
        Zikr Apps · Engineering notes
      </p>
      <h1 class="mt-4 font-serif text-4xl leading-tight font-semibold sm:text-5xl">
        From flaky to flawless: making our app tests trustworthy
      </h1>
      <p class="mt-5 max-w-2xl text-base leading-relaxed text-cream/80 sm:text-lg">
        We set out to run our Misbaha app through 150 automated tests and trust the result.
        It started at a frustrating 84%. This is the story of why automated tests lie, the
        dead ends we hit, and how we reached a clean 100% — with before-and-after pictures
        for every problem.
      </p>

      <dl class="mt-8 grid grid-cols-2 gap-4 sm:grid-cols-4">
        {
          heroStats.map((s) => (
            <div class="rounded-2xl border border-cream/15 bg-cream/5 p-4">
              <dt class="text-xs tracking-wide text-cream/60 uppercase">{s.label}</dt>
              <dd class="mt-1 font-serif text-3xl font-semibold text-gold-light">{s.value}</dd>
            </div>
          ))
        }
      </dl>
      <p class="mt-6 text-xs text-cream/50">Last updated {lastUpdated}</p>
    </div>
  </section>

  <!-- Table of contents -->
  <section class="bg-cream mashrabiya pt-8 sm:pt-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6">
      <nav class="rounded-3xl border border-forest/10 bg-white/60 p-5 sm:p-6" aria-label="Table of contents">
        <h2 class="font-serif text-2xl font-semibold text-forest">On this page</h2>
        <ol class="mt-4 grid gap-x-8 gap-y-0.5 sm:grid-cols-2">
          {
            toc.map((item, i) => (
              <li>
                <a
                  href={`#${item.id}`}
                  class="group flex items-baseline gap-3 rounded-lg px-2 py-1.5 text-forest/85 transition-colors hover:bg-cream hover:text-forest"
                >
                  <span class="font-serif text-sm font-semibold text-gold tabular-nums">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <span class="group-hover:underline">{item.label}</span>
                </a>
              </li>
            ))
          }
        </ol>
      </nav>
    </div>
  </section>

  <!-- Introduction: meet Misbaha (75s video) -->
