---
import BaseLayout from '../../layouts/BaseLayout.astro';
import type { Locale } from '../../i18n';
import { getTranslations } from '../../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getTranslations(locale);
const formEndpoint = import.meta.env.PUBLIC_FORM_ENDPOINT ?? '';
---

<BaseLayout locale={locale} t={t} title={t.contact.title} description={t.contact.subtitle}>
  <section class="bg-cream mashrabiya py-12 sm:py-20">
    <div class="mx-auto max-w-xl px-4 sm:px-6">
      <h1 class="font-serif text-4xl font-semibold text-forest">{t.contact.title}</h1>
      <p class="mt-3 text-forest/80">{t.contact.subtitle}</p>

      <aside
        class="mt-8 rounded-2xl border-2 border-gold/40 bg-gold/10 p-5 sm:p-6"
        role="note"
        aria-labelledby="authenticity-title"
      >
        <div class="flex items-start gap-3">
          <span
            class="mt-0.5 inline-flex h-7 w-7 flex-none items-center justify-center rounded-full bg-gold/30 text-forest"
            aria-hidden="true"
          >
            <svg viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
              <path
                fill-rule="evenodd"
                d="M10 1.5a8.5 8.5 0 1 0 0 17 8.5 8.5 0 0 0 0-17ZM9 6a1 1 0 1 1 2 0v5a1 1 0 1 1-2 0V6Zm1 7.25a1.125 1.125 0 1 0 0 2.25 1.125 1.125 0 0 0 0-2.25Z"
                clip-rule="evenodd"
              ></path>
            </svg>
          </span>
          <div>
            <h2 id="authenticity-title" class="font-serif text-lg font-semibold text-forest">
              {t.contact.disclaimer.title}
            </h2>
            <p class="mt-2 text-sm leading-relaxed text-forest/85">
              {t.contact.disclaimer.body}
            </p>
          </div>
        </div>
      </aside>

      <form class="contact-form mt-10 space-y-5" method="POST" action={formEndpoint || undefined} data-form>
        {!formEndpoint && (
          <p class="rounded-lg border border-gold/40 bg-gold/10 px-4 py-3 text-sm text-forest/80">
            Set <code class="text-xs">PUBLIC_FORM_ENDPOINT</code> in <code class="text-xs">.env</code> (Formspree or Web3Forms) to enable submissions.
          </p>
        )}

        <div>
          <label for="name" class="mb-1 block text-sm font-medium text-forest">{t.contact.name}</label>
          <input
            id="name"
            name="name"
            type="text"
            required
            autocomplete="name"
            class="w-full rounded-lg border border-forest/15 bg-white/60 px-4 py-3 text-forest outline-none focus:border-forest focus:ring-1 focus:ring-forest"
          />
        </div>

        <div>
          <label for="email" class="mb-1 block text-sm font-medium text-forest">{t.contact.email}</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="w-full rounded-lg border border-forest/15 bg-white/60 px-4 py-3 text-forest outline-none focus:border-forest focus:ring-1 focus:ring-forest"
          />
        </div>

        <div>
          <label for="app" class="mb-1 block text-sm font-medium text-forest">{t.contact.app}</label>
          <select
            id="app"
            name="app"
            class="w-full rounded-lg border border-forest/15 bg-white/60 px-4 py-3 text-forest outline-none focus:border-forest"
          >
            {t.contact.appOptions.map((opt) => (
              <option value={opt.value}>{opt.label}</option>
            ))}
          </select>
        </div>

        <div>
          <label for="message" class="mb-1 block text-sm font-medium text-forest">{t.contact.message}</label>
          <textarea
            id="message"
            name="message"
            rows={5}
            required
            class="w-full resize-y rounded-lg border border-forest/15 bg-white/60 px-4 py-3 text-forest outline-none focus:border-forest focus:ring-1 focus:ring-forest"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-full rounded-lg bg-forest px-6 py-4 text-sm font-semibold text-cream transition-colors hover:bg-forest-deep sm:w-auto"
        >
          {t.contact.submit}
        </button>

        <p class="text-xs text-forest/60">{t.contact.privacy}</p>
        <p class="hidden text-sm text-forest" data-success>{t.contact.success}</p>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.querySelector('[data-form]');
  form?.addEventListener('submit', async (e) => {
    const action = form.getAttribute('action');
    if (!action) {
      e.preventDefault();
      alert('Form endpoint not configured yet.');
      return;
    }
    e.preventDefault();
    const data = new FormData(form);
    const res = await fetch(action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
    if (res.ok) {
      form.reset();
      form.querySelector('[data-success]')?.classList.remove('hidden');
    }
  });
</script>
