---
import type { Locale } from '../i18n';
import { appStoreBadgeSrc } from '../lib/store-badges';

interface Props {
  locale: Locale;
  surface?: 'light' | 'dark';
  appStoreUrl?: string;
  playStoreUrl?: string;
  playStoreComingSoon?: boolean;
  playStoreComingSoonLabel: string;
  appStoreLabel: string;
  playStoreLabel: string;
}

const {
  locale,
  surface = 'light',
  appStoreUrl,
  playStoreUrl,
  playStoreComingSoon = false,
  playStoreComingSoonLabel,
  appStoreLabel,
  playStoreLabel,
} = Astro.props;

const showAppStore = appStoreUrl && appStoreUrl !== '#';
const showPlayStore = playStoreUrl && playStoreUrl !== '#';
const appStoreBadge = showAppStore ? appStoreBadgeSrc(locale, surface) : null;
const comingSoonClass =
  surface === 'dark'
    ? 'border-cream/25 text-cream/60'
    : 'border-forest/20 text-forest/55';
---

<div class="flex flex-wrap items-center gap-3">
  {
    showAppStore && appStoreBadge && (
      <a href={appStoreUrl} target="_blank" rel="noopener noreferrer" class="inline-block transition-opacity hover:opacity-90">
        <img
          src={appStoreBadge}
          alt={appStoreLabel}
          width={250}
          height={83}
          class="h-10 w-auto sm:h-11"
          loading="lazy"
          decoding="async"
        />
      </a>
    )
  }
  {
    showPlayStore && (
      <a
        href={playStoreUrl}
        target="_blank"
        rel="noopener noreferrer"
        class:list={[
          'inline-flex h-11 items-center rounded-lg border-2 px-4 text-xs font-medium transition-colors',
          surface === 'dark'
            ? 'border-cream text-cream hover:bg-cream hover:text-forest'
            : 'border-forest bg-transparent text-forest hover:bg-forest hover:text-cream',
        ]}
      >
        {playStoreLabel}
      </a>
    )
  }
  {
    playStoreComingSoon && !showPlayStore && (
      <span
        class:list={[
          'inline-flex h-11 items-center rounded-lg border px-4 text-xs font-medium',
          comingSoonClass,
        ]}
      >
        {playStoreComingSoonLabel}
      </span>
    )
  }
</div>
