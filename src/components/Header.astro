---
import type { Locale, Translations } from '../i18n';
import { appPath, contactPath, homePath, withSiteOrigin } from '../lib/paths';
import LanguageToggle from './LanguageToggle.astro';
import Logo from './icons/Logo.astro';
import Wordmark from './icons/Wordmark.astro';

interface Props {
  locale: Locale;
  t: Translations;
  transparent?: boolean;
  linkOrigin?: string;
}

const { locale, t, transparent = false, linkOrigin } = Astro.props;
const link = (path: string) => withSiteOrigin(path, linkOrigin);
const apps = [
  { slug: 'tazkirah' as const, label: t.nav.tazkirah },
  { slug: 'misbaha' as const, label: t.nav.misbaha },
  { slug: 'mehrab' as const, label: t.nav.mehrab },
];
---

<header
  class:list={[
    'sticky top-0 z-50 border-b border-forest/5 backdrop-blur-md',
    transparent ? 'bg-cream/80' : 'bg-cream/95',
  ]}
>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href={link(homePath(locale))} class="flex items-center gap-2.5 text-forest transition-opacity hover:opacity-80">
      <Logo class="h-9 w-auto" variant="primary" />
      <Wordmark locale={locale} brand={t.nav.brand} size="md" />
    </a>

    <nav class="hidden items-center gap-6 md:flex" aria-label="Main">
      {
        apps.map((app) => (
          <a
            href={link(appPath(app.slug, locale))}
            class="text-sm font-medium text-forest/80 transition-colors hover:text-forest"
          >
            {app.label}
          </a>
        ))
      }
      <a
        href={link(contactPath(locale))}
        class="text-sm font-medium text-forest/80 transition-colors hover:text-forest"
      >
        {t.nav.contact}
      </a>
    </nav>

    <div class="flex items-center gap-3">
      <LanguageToggle locale={locale} labels={t.lang} linkOrigin={linkOrigin} />
      <button
        type="button"
        class="mobile-menu-btn flex h-10 w-10 items-center justify-center rounded-lg border border-forest/10 text-forest md:hidden"
        aria-label="Menu"
        aria-expanded="false"
        data-menu-toggle
      >
        <span class="sr-only">Menu</span>
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <nav
    class="mobile-nav hidden border-t border-forest/10 bg-cream px-4 py-4 md:hidden"
    data-mobile-nav
    aria-label="Mobile"
  >
    <ul class="flex flex-col gap-3">
      {
        apps.map((app) => (
          <li>
            <a href={link(appPath(app.slug, locale))} class="block py-1 font-medium text-forest">
              {app.label}
            </a>
          </li>
        ))
      }
      <li>
        <a href={link(contactPath(locale))} class="block py-1 font-medium text-forest">
          {t.nav.contact}
        </a>
      </li>
    </ul>
  </nav>
</header>

<script>
  document.querySelectorAll('[data-menu-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const nav = document.querySelector('[data-mobile-nav]');
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      nav?.classList.toggle('hidden');
    });
  });
</script>
