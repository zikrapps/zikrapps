---
import type { Locale } from '../i18n';
import { switchLocalePath } from '../i18n';

interface Props {
  locale: Locale;
  labels: { en: string; ar: string; ur: string };
  linkOrigin?: string;
}

const { locale, labels, linkOrigin } = Astro.props;
const pathname = Astro.url.pathname;
const link = (path: string) => (linkOrigin ? new URL(path, linkOrigin).href : path);

const locales: { code: Locale; label: string; flag: string }[] = [
  {
    code: 'en',
    label: labels.en,
    flag: '🇺🇸',
  },
  {
    code: 'ar',
    label: labels.ar,
    flag: '🇸🇦',
  },
  {
    code: 'ur',
    label: labels.ur,
    flag: '🇵🇰',
  },
];
---

<nav class="lang-toggle flex items-center gap-1 rounded-full border border-forest/10 bg-cream-dark/60 p-1" aria-label="Language">
  {
    locales.map(({ code, label, flag }) => {
      const href = link(switchLocalePath(pathname, code));
      const active = locale === code;
      return (
        <a
          href={href}
          hreflang={code}
          lang={code}
          class:list={[
            'flex items-center gap-1.5 rounded-full px-2.5 py-1.5 text-xs font-medium transition-colors sm:px-3',
            active
              ? 'bg-gold text-forest shadow-sm'
              : 'text-forest/70 hover:bg-cream hover:text-forest',
          ]}
          aria-current={active ? 'page' : undefined}
        >
          <span class="text-sm leading-none" aria-hidden="true">{flag}</span>
          <span class="hidden sm:inline">{label}</span>
          <span class="sm:hidden uppercase">{code}</span>
        </a>
      );
    })
  }
</nav>
