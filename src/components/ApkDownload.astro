---
import { APK_BASE_URL } from '../lib/apk-base-url';

interface Props {
  filename: string;
  label: string;
  prominent?: boolean;
}

const { filename, label, prominent = true } = Astro.props;

// Production: GitHub Releases (see src/lib/apk-base-url.ts).
// Local dev: set PUBLIC_APK_BASE_URL empty in .env to use public/downloads/.
const useGitHub = Boolean(import.meta.env.PUBLIC_APK_BASE_URL) || import.meta.env.PROD;
const href = useGitHub ? `${APK_BASE_URL}/${filename}` : `/downloads/${filename}`;
// `download` only works same-origin; external APK URLs should open normally.
const isExternal = href.startsWith('http');
---

<a
  href={href}
  {...!isExternal && { download: true }}
  class:list={[
    'inline-flex items-center justify-center gap-2 rounded-lg font-semibold transition-all',
    prominent
      ? 'w-full bg-gold px-6 py-4 text-forest shadow-lg shadow-gold/20 hover:bg-gold-light sm:w-auto'
      : 'border border-gold bg-gold/10 px-4 py-2 text-sm text-forest hover:bg-gold/20',
  ]}
>
  <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5m0 0l5-5m-5 5V4"></path>
  </svg>
  {label}
</a>
