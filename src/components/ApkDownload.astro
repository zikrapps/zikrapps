---
interface Props {
  filename: string;
  label: string;
  prominent?: boolean;
}

const { filename, label, prominent = true } = Astro.props;
// In production we serve APKs from GitHub Releases (free, supports large
// files, no bandwidth fees). Locally we fall back to public/downloads/ so
// `npm run dev` still works without an internet round-trip.
//
// Set PUBLIC_APK_BASE_URL in .env / your hosting provider, e.g.:
//   PUBLIC_APK_BASE_URL=https://github.com/<user>/zikrapps/releases/download/v0.1.0-beta
const baseUrl = (import.meta.env.PUBLIC_APK_BASE_URL ?? '').replace(/\/$/, '');
const href = baseUrl ? `${baseUrl}/${filename}` : `/downloads/${filename}`;
---

<a
  href={href}
  download
  class:list={[
    'inline-flex items-center justify-center gap-2 rounded-lg font-semibold transition-all',
    prominent
      ? 'w-full bg-gold px-6 py-4 text-forest shadow-lg shadow-gold/20 hover:bg-gold-light sm:w-auto'
      : 'border border-gold bg-gold/10 px-4 py-2 text-sm text-forest hover:bg-gold/20',
  ]}
>
  <svg class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5m0 0l5-5m-5 5V4"></path>
  </svg>
  {label}
</a>
