---
interface Props {
  videoSrc: string;
  poster?: string;
  label: string;
  closeLabel: string;
  variant?: 'thumbnail' | 'play-button';
  /** For play-button: use on cream (light) or forest (dark) sections */
  surface?: 'light' | 'dark';
  class?: string;
}

const {
  videoSrc,
  poster,
  label,
  closeLabel,
  variant = 'thumbnail',
  surface = 'dark',
  class: className = '',
} = Astro.props;

const playBtnClass =
  surface === 'light'
    ? 'border-forest bg-forest text-cream focus-visible:ring-forest'
    : 'border-cream bg-cream text-forest focus-visible:ring-cream';
---

<div class:list={['video-modal', className]} data-video-modal>
  {
    variant === 'thumbnail' ? (
      <button
        type="button"
        class="group relative mx-auto block w-full max-w-[280px] overflow-hidden rounded-2xl border border-cream/20 bg-forest-deep shadow-xl focus:outline-none focus-visible:ring-2 focus-visible:ring-gold focus-visible:ring-offset-2 focus-visible:ring-offset-forest sm:max-w-[320px]"
        data-video-open
        aria-haspopup="dialog"
      >
        {poster && (
          <img
            src={poster}
            alt=""
            class="aspect-[9/19] w-full object-cover object-top opacity-90 transition-opacity group-hover:opacity-100"
            loading="lazy"
          />
        )}
        <span class="absolute inset-0 flex items-center justify-center bg-forest/30 transition-colors group-hover:bg-forest/40">
          <span class="flex h-16 w-16 items-center justify-center rounded-full bg-cream text-forest shadow-lg transition-transform group-hover:scale-105 sm:h-20 sm:w-20">
            <svg class="ms-1 h-8 w-8 sm:h-10 sm:w-10" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M8 5v14l11-7z" />
            </svg>
          </span>
        </span>
        <span class="sr-only">{label}</span>
      </button>
    ) : (
      <button
        type="button"
        class:list={[
          'flex h-14 w-14 items-center justify-center rounded-full border-2 shadow-lg transition-transform hover:scale-105 focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2',
          playBtnClass,
        ]}
        data-video-open
        aria-haspopup="dialog"
        title={label}
      >
        <svg class="ms-0.5 h-6 w-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M8 5v14l11-7z" />
        </svg>
        <span class="sr-only">{label}</span>
      </button>
    )
  }

  <div
    class="video-modal__dialog fixed inset-0 z-[100] hidden items-center justify-center p-4 sm:p-8"
    data-video-dialog
    role="dialog"
    aria-modal="true"
    aria-label={label}
    hidden
  >
    <button
      type="button"
      class="video-modal__backdrop absolute inset-0 bg-forest/75 backdrop-blur-sm"
      data-video-backdrop
      aria-label={closeLabel}
    />

    <div
      class="video-modal__panel relative z-10 w-[min(92vw,340px)] overflow-hidden rounded-2xl bg-forest-deep shadow-2xl ring-1 ring-cream/20"
      data-video-panel
    >
      <button
        type="button"
        class="absolute end-2 top-2 z-20 flex h-9 w-9 items-center justify-center rounded-full bg-forest/90 text-cream shadow-md backdrop-blur-sm transition-colors hover:bg-forest focus:outline-none focus-visible:ring-2 focus-visible:ring-gold"
        data-video-close
        aria-label={closeLabel}
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
      <video
        class="block max-h-[85dvh] w-full object-contain"
        controls
        playsinline
        preload="none"
        data-video-player
      >
        <source src={videoSrc} type="video/mp4" />
      </video>
    </div>
  </div>
</div>

<script>
  function initVideoModals() {
    document.querySelectorAll('[data-video-modal]').forEach((root) => {
      if (root.dataset.videoBound === 'true') return;
      root.dataset.videoBound = 'true';

      const dialog = root.querySelector('[data-video-dialog]');
      const backdrop = root.querySelector('[data-video-backdrop]');
      const closeBtn = root.querySelector('[data-video-close]');
      const panel = root.querySelector('[data-video-panel]');
      const openBtn = root.querySelector('[data-video-open]');
      const video = root.querySelector('[data-video-player]');

      if (!dialog || !openBtn || !video) return;

      let lastFocus: HTMLElement | null = null;

      const close = () => {
        dialog.classList.add('hidden');
        dialog.classList.remove('flex');
        dialog.setAttribute('hidden', '');
        document.body.style.overflow = '';
        video.pause();
        video.currentTime = 0;
        lastFocus?.focus();
      };

      const open = () => {
        lastFocus = document.activeElement instanceof HTMLElement ? document.activeElement : null;
        dialog.classList.remove('hidden');
        dialog.classList.add('flex');
        dialog.removeAttribute('hidden');
        document.body.style.overflow = 'hidden';
        video.play().catch(() => {});
      };

      openBtn.addEventListener('click', open);
      backdrop?.addEventListener('click', close);
      closeBtn?.addEventListener('click', close);
      panel?.addEventListener('click', (e) => e.stopPropagation());

      dialog.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });
    });
  }

  initVideoModals();
  document.addEventListener('astro:page-load', initVideoModals);
</script>
